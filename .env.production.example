# ============================================
# BULONERA WEB - PRODUCCIÓN VPS
# ============================================
# Este archivo es un TEMPLATE para el .env de producción
# Copiar a .env en el VPS y completar con valores reales
# NUNCA commitear el .env real con credenciales

# ============================================
# DJANGO CORE
# ============================================
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CAMBIAR_POR_SECRET_KEY_GENERADO

DEBUG=False
ALLOWED_HOSTS=[*]

# ============================================
# BASE DE DATOS - MariaDB en HOST del VPS
# ============================================
# IMPORTANTE: host.docker.internal resuelve al IP del host desde Docker
DB_NAME=nombre_db
DB_USER=nombre_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_BD
DB_HOST=host.docker.internal
DB_PORT=3306

# ============================================
# SITIO
# ============================================
SITE_URL=https://tu_url.online
META_PIXEL_ID=numero_pixel
WHATSAPP_NUMBER=tu_whatsapp

# ============================================
# EMAILS - SMTP Hostinger
# ============================================
EMAIL_TO_SEND_MESSAGES=cambiar_por_tu_email
EMAIL_TO_RECEIVE_MESSAGES=cambiar_por_tu_email
SMTP_HOST=smtp.host_tuyo.com
SMTP_PORT=587
SMTP_USER=cambiar_por_tu_email
SMTP_PASSWORD=CAMBIAR_POR_PASSWORD_SMTP

# ============================================
# PATHS - Docker Volumes
# ============================================
STATIC_ROOT=/app/staticfiles
MEDIA_ROOT=/app/media
LOG_DIR=/app/logs

# Paths en el HOST del VPS (montados como volúmenes)
BULONERA_SHARED_MEDIA_PATH=/var/www/app/media
BULONERA_LOG_PATH=/var/www/app/logs

# ============================================
# REDIS - Usar DBs distintas al ERP
# ============================================
# VERIFICAR qué DBs usa el ERP antes de asignar
# El ERP probablemente usa /0 y /1
# Asignamos /3, /4, /5 para la web
CELERY_BROKER_URL=redis://host.docker.internal:6379/3
CELERY_RESULT_BACKEND=redis://host.docker.internal:6379/4
REDIS_URL=redis://host.docker.internal:6379/5

# ============================================
# CACHE
# ============================================
CACHE_TTL=300

# ============================================
# DJANGO SETTINGS MODULE
# ============================================
DJANGO_SETTINGS_MODULE=app.settings.production
